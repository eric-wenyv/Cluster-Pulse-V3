{
  "name": "cluster-pulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "data": "python3 scripts/build_data.py --input-root data/raw --fallback-root data/raw-sample --output-root public/data",
    "data:sample": "bash scripts/download_alibaba.sh sample && npm run data",
    "check:data": "python3 scripts/verify_data.py public/data",
    "build": "npm run check:data && tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.9"
  }
}
